set_option autoImplicit false

namespace Gains

inductive GainsGroup where
  | crypto
  | forex
  | stocks_1
  | stocks_2
  | stocks_3
  | indices
  | commodities_1
  | commodities_2
  | forex_minor
  | forex_exotic
  | altcoins
  | crypto_degen
  deriving DecidableEq, Repr

structure GainsGroupSpec where
  index : Nat
  minLeverage : Nat
  maxLeverage : Nat
  deriving Repr

def GainsGroup.spec : GainsGroup → GainsGroupSpec
  | .crypto => { index := 0, minLeverage := 1100, maxLeverage := 200000 }
  | .forex => { index := 1, minLeverage := 10000, maxLeverage := 1000000 }
  | .stocks_1 => { index := 2, minLeverage := 1100, maxLeverage := 50000 }
  | .stocks_2 => { index := 3, minLeverage := 1100, maxLeverage := 50000 }
  | .stocks_3 => { index := 4, minLeverage := 1100, maxLeverage := 50000 }
  | .indices => { index := 5, minLeverage := 1100, maxLeverage := 100000 }
  | .commodities_1 => { index := 6, minLeverage := 2000, maxLeverage := 250000 }
  | .commodities_2 => { index := 7, minLeverage := 2000, maxLeverage := 150000 }
  | .forex_minor => { index := 8, minLeverage := 10000, maxLeverage := 750000 }
  | .forex_exotic => { index := 9, minLeverage := 10000, maxLeverage := 500000 }
  | .altcoins => { index := 10, minLeverage := 1100, maxLeverage := 150000 }
  | .crypto_degen => { index := 11, minLeverage := 500000, maxLeverage := 500001 }

def GainsGroup.index (g : GainsGroup) : Nat := g.spec.index
def GainsGroup.minLeverage (g : GainsGroup) : Nat := g.spec.minLeverage
def GainsGroup.maxLeverage (g : GainsGroup) : Nat := g.spec.maxLeverage

structure GainsFee where
  feeIndex : Nat
  totalPositionSizeFeeP : Nat
  totalLiqCollateralFeeP : Nat
  oraclePositionSizeFeeP : Nat
  minPositionSizeUsd : Nat
  deriving Repr

inductive GainsOrderType where
  | market
  | limit
  deriving DecidableEq, Repr

structure GainsOrder where
  pair : GainsPair
  long : Bool
  collateralAmount : Nat
  leverage : Nat
  orderType : GainsOrderType
  limitPrice : Option Nat
  tp : Option Nat
  sl : Option Nat
  deriving Repr

structure GainsPair where
  pairIndex : Nat
  from : String
  to : String
  group : GainsGroup
  feeIndex : Nat
  spreadP : Nat
  deriving Repr

def GainsPair.symbol (p : GainsPair) : String := s!"{p.from}/{p.to}"

private def fee (feeIndex totalPositionSizeFeeP minPositionSizeUsd : Nat) : GainsFee :=
  { feeIndex := feeIndex
  , totalPositionSizeFeeP := totalPositionSizeFeeP
  , totalLiqCollateralFeeP := 100000000000
  , oraclePositionSizeFeeP := 0
  , minPositionSizeUsd := minPositionSizeUsd
  }

private def pair (pairIndex : Nat) (from to : String) (group : GainsGroup) (feeIndex spreadP : Nat) : GainsPair :=
  { pairIndex := pairIndex, from := from, to := to, group := group, feeIndex := feeIndex, spreadP := spreadP }

private def usd (pairIndex : Nat) (from : String) (group : GainsGroup) (feeIndex : Nat) (spreadP : Nat := 0) : GainsPair :=
  pair pairIndex from "USD" group feeIndex spreadP

