inductive OrderKind
  | market | limit
  deriving DecidableEq, BEq, Hashable, Repr

structure Execution where
  asset      : Asset
  venue      : Venue
  network    : Network
  side       : Side
  leverage   : Nat
  orderKind  : OrderKind
  size       : Money
  limitPrice : Option Money
  stopLoss   : Option Money
  takeProfit : Option Money
  deriving Repr

-- the goal is to make execution filter out duplicate assets by context
-- we send execute signal to server as either 
-- BTC w/ X Leverage on SOL Network (Drift BTC) or on Arb network (Gains) and so forth

def resolve (e : Execution) : Route :=
  { venue := e.venue, asset := e.asset, side := e.side,
    size := e.size, leverage := e.leverage }

def validate (e : Execution) : Option Route :=
  if e.asset = Asset.btc ∧ e.venue = Venue.drift ∧ e.network = Network.solana ∧ e.leverage ≤ 100 then
    some { venue := e.venue, asset := e.asset, side := e.side,
           size := e.size, leverage := e.leverage }
  else
    none

